# Discord Bot
# Create your bot at https://discord.com/developers/applications
BOT_TOKEN=your-discord-bot-token-here
GUILD_ID=your-discord-server-id
CHANNEL_ID=your-announcement-channel-id

# Scraping backend — set one key depending on your hosting environment.
# The bot tries Zyte first, then ScraperAPI, then falls back to a direct request.
# If you're hosting on a home/residential connection, Cloudflare won't block you
# and you can leave both keys unset.
#
# Zyte API (pay-as-you-go): https://www.zyte.com
ZYTE_API_KEY=your-zyte-api-key-here
#
# ScraperAPI (1,000 free credits/month): https://www.scraperapi.com
# SCRAPER_API_KEY=your-scraperapi-key-here

# How often to scrape within the active window (in hours).
POLL_INTERVAL_HOURS=3

# Active scraping window — the bot only scrapes during this time range each day.
# Uses 24-hour format. Set START=0 and END=24 to scrape around the clock.
# SCRAPE_TIMEZONE accepts any IANA timezone name (e.g. America/Chicago, Europe/London).
SCRAPE_WINDOW_START=8
SCRAPE_WINDOW_END=21
SCRAPE_TIMEZONE=America/New_York
